# Database
DATABASE_URL="postgresql://user:password@localhost:5432/interview_prep_db?schema=public"

# Auth (NEVER commit real values — use .env only)
GOOGLE_CLIENT_ID="your-google-client-id"
JWT_SECRET="generate-a-strong-random-secret"
OPENAI_API_KEY="your-openai-api-key"

# Feature flags
USE_MOCK_AI=true

# Optional
FRONTEND_URL=http://localhost:5000
PORT=5000
